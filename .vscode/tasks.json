{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend-ts" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^(.*)$", "file": 1, "line": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "▲ Next\\.js",
          "endsPattern": "Ready in"
        }
      },
      "presentation": { "group": "debug", "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "stopBackend",
      "type": "shell",
      "command": "lsof -t -i:8000 | xargs kill -9 2>/dev/null; true",
      "presentation": { "reveal": "silent", "panel": "shared", "close": true }
    },
    {
      "label": "stopFrontend",
      "type": "shell",
      "command": "lsof -t -i:3000 | xargs kill -9 2>/dev/null; true",
      "presentation": { "reveal": "silent", "panel": "shared", "close": true }
    }
  ]
}
